# Files in this directory that must NOT be published as static assets.
# (Wrangler uploads everything in assets.directory except these.)
node_modules
src
package.json
package-lock.json
wrangler.jsonc
.assetsignore
.gitignore
.git
.dev.vars*
.env*
.wrangler
README.md
# Agent scratch space and git worktrees live here. A worktree under the asset
# root is a full second copy of the site, so without this line `wrangler deploy`
# publishes unreleased branches at /.claude/worktrees/<branch>/. It has happened.
.claude
